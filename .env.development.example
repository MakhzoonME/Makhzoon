# =============================================================================
# DEVELOPMENT ENVIRONMENT (dev branch -> dev.makhzoon.me)
# =============================================================================
# Paste this into Vercel:
#   Project: makhzoon-dev
#   Settings -> Environment Variables -> Import .env -> select "Development"
#     and "Preview" scopes (NOT Production)
# Fill in the blanks before importing.
# =============================================================================

# --- Firebase Client (public, safe to expose) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=makhzoon-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=makhzoon-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=makhzoon-dev.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server-side only, NEVER expose to client) ---
# From Firebase Console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_PROJECT_ID=makhzoon-dev
FIREBASE_CLIENT_EMAIL=
# Paste full key including BEGIN/END lines, keep \n as literal escapes, wrap in quotes
FIREBASE_PRIVATE_KEY=""

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://dev.makhzoon.me
NODE_ENV=development
# Explicit environment identifier. Values: development | staging | production
# Do NOT rely on NODE_ENV — Vercel sets NODE_ENV=production for Preview and Production.
NEXT_PUBLIC_APP_ENV=development

# --- Email (Resend) ---
# Use a separate Resend API key for dev so you don't pollute prod analytics
RESEND_API_KEY=
RESEND_FROM_EMAIL=Makhzoon Dev <dev-notifications@makhzoon.me>

# --- Cron ---
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Cloudflare Turnstile ---
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
