# =============================================================================
# MAKHZOON ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# For environment-specific configs, see:
#   - .env.local.example (development)
#   - .env.staging.example (staging)
#   - .env.production.example (production)
# =============================================================================

# --- RUNTIME ENVIRONMENT ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- FIREBASE CLIENT (Public — safe to expose in browser) ---
# Get these from Firebase Console > Project Settings > General tab
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- FIREBASE ADMIN (Server-side only — NEVER expose to client) ---
# Get these from Firebase Console > Project Settings > Service Accounts > Generate new private key
# WARNING: Keep FIREBASE_PRIVATE_KEY secret. Store in password manager, not version control.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- EMAIL SERVICE (Resend) ---
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Makhzoon <notifications@your-domain.com>

# --- SMS SERVICE (Twilio) ---
# Get credentials from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# --- CRON JOBS ---
# Shared secret required in Authorization header for /api/cron/* routes.
# Vercel Cron sends this automatically when configured via `CRON_SECRET` env var.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- ERROR TRACKING (Sentry) ---
# Get from https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- SUPABASE (Public — safe to expose in browser) ---
# Get these from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- SUPABASE ADMIN (Server-side only — NEVER expose to client) ---
# Get from Supabase Dashboard > Project Settings > API > service_role key
# WARNING: Keep SUPABASE_SERVICE_ROLE_KEY secret.
SUPABASE_SERVICE_ROLE_KEY=

# --- BOT PROTECTION (Cloudflare Turnstile) ---
# Get keys from https://dash.cloudflare.com/
# Set CLOUDFLARE_TURNSTILE_SECRET_KEY to enable bot protection on signup/login forms
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
