# Firebase Client (public — safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDA6d4JJbuOTVFRFDfKoArFr5W4jUqCEhY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=office-asset-system.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=office-asset-system
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=office-asset-system.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=655264017714
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server-side only — NEVER expose to client)
FIREBASE_PROJECT_ID=office-asset-system
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
# Explicit environment identifier. Values: development | staging | production
# Do NOT rely on NODE_ENV — Vercel sets NODE_ENV=production for Preview and Production.
NEXT_PUBLIC_APP_ENV=development

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Makhzoon <notifications@your-domain.com>

# Cron
# Shared secret required in Authorization header for /api/cron/* routes.
# Vercel Cron sends this automatically when configured via `CRON_SECRET` env var.
CRON_SECRET=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Cloudflare Turnstile
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
