# Firebase Client (public — safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here

# Firebase Admin (server-side only — NEVER expose to client)
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_CLIENT_EMAIL=your_firebase_client_email_here
FIREBASE_PRIVATE_KEY=your_firebase_private_key_here

# Supabase (public — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Admin (server-side only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public host that serves shareable receipts (/r/[orgSlug]/preview)
NEXT_PUBLIC_RECEIPT_URL=http://localhost:3000
NODE_ENV=development
# Explicit environment identifier. Values: development | staging | production
# Do NOT rely on NODE_ENV — Vercel sets NODE_ENV=production for Preview and Production.
NEXT_PUBLIC_APP_ENV=development

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Makhzoon <notifications@your-domain.com>

# Cron
# Shared secret required in Authorization header for /api/cron/* routes.
# Vercel Cron sends this automatically when configured via `CRON_SECRET` env var.
CRON_SECRET=

# AWS S3
APP_AWS_REGION=eu-north-1
APP_AWS_ACCESS_KEY_ID=your_iam_access_key_here
APP_AWS_SECRET_ACCESS_KEY=your_iam_secret_key_here
APP_AWS_S3_BUCKET_NAME=your_bucket_name_here

# Local-only auth bypass (LOCAL DEVELOPMENT ONLY).
# Set to a real public.users.id UUID to skip the login step when running
# `next dev`. Only honored when NODE_ENV === 'development', so deployed
# envs (which run NODE_ENV=production) ignore it.
# Leave blank to disable. Never commit a value.
LOCAL_AUTH_BYPASS_USER_ID=

# Google Drive (server-side only — NEVER expose to client)
# Service account email from the JSON key file ('client_email' field)
GOOGLE_DRIVE_CLIENT_EMAIL=your_google_drive_client_email_here
# Service account private key from the JSON key file ('private_key' field).
# Keep the surrounding double quotes; use the value as-is with \n escapes.
GOOGLE_DRIVE_PRIVATE_KEY="your_google_drive_private_key_here"
# ID of the Drive folder shared with the service account (from the folder URL).
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
