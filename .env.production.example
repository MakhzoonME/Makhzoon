# =============================================================================
# PRODUCTION ENVIRONMENT (main branch -> makhzoon.me)
# =============================================================================
# Paste this into Vercel:
#   Project: makhzoon-prod (or makhzoon)
#   Settings -> Environment Variables -> Import .env -> select "Production"
#     scope only
# Fill in the blanks before importing.
#
# WARNING: These values touch real customer data. Treat the filled-in version
# as a secret. Store it in a password manager, NOT a chat or repo.
# =============================================================================

# --- Firebase Client (public, safe to expose) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=makhzoon-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=makhzoon-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=makhzoon-prod.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server-side only, NEVER expose to client) ---
# From Firebase Console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_PROJECT_ID=makhzoon-prod
FIREBASE_CLIENT_EMAIL=
# Paste full key including BEGIN/END lines, keep \n as literal escapes, wrap in quotes
FIREBASE_PRIVATE_KEY=""

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://makhzoon.me
NODE_ENV=production

# --- Email (Resend) ---
# Production Resend API key, verified domain
RESEND_API_KEY=
RESEND_FROM_EMAIL=Makhzoon <notifications@makhzoon.me>

# --- Cron ---
# Generate with: openssl rand -hex 32  (different value from dev and staging)
CRON_SECRET=

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Cloudflare Turnstile ---
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
