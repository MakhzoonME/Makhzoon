# --- App Config ---
NEXT_PUBLIC_APP_URL=https://makhzoon.me
NODE_ENV=production
# Explicit environment identifier. Values: development | staging | production
# Do NOT rely on NODE_ENV — Vercel sets NODE_ENV=production for Preview and Production.
NEXT_PUBLIC_APP_ENV=production

# --- Email (Resend) ---
# Production Resend API key, verified domain
RESEND_API_KEY=
RESEND_FROM_EMAIL=Makhzoon <notifications@makhzoon.me>

# --- Cron ---
# Generate with: openssl rand -hex 32  (different value from dev and staging)
CRON_SECRET=

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Cloudflare Turnstile ---
