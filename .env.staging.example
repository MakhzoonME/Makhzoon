# =============================================================================
# STAGING ENVIRONMENT (staging branch -> staging.makhzoon.me)
# =============================================================================
# Paste this into Vercel:
#   Project: makhzoon-staging
#   Settings -> Environment Variables -> Import .env -> select "Production"
#     scope only (this Vercel project is dedicated to staging)
# Fill in the blanks before importing.
# =============================================================================

# --- Firebase Client (public, safe to expose) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=makhzoon-staging.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=makhzoon-staging
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=makhzoon-staging.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server-side only, NEVER expose to client) ---
# From Firebase Console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_PROJECT_ID=makhzoon-staging
FIREBASE_CLIENT_EMAIL=
# Paste full key including BEGIN/END lines, keep \n as literal escapes, wrap in quotes
FIREBASE_PRIVATE_KEY=""

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://staging.makhzoon.me
NODE_ENV=production
# Explicit environment identifier. Values: development | staging | production
# Do NOT rely on NODE_ENV — Vercel sets NODE_ENV=production for Preview and Production.
NEXT_PUBLIC_APP_ENV=staging

# --- Email (Resend) ---
# Use a separate Resend API key (or sandbox domain) so QA doesn't email real users
RESEND_API_KEY=
RESEND_FROM_EMAIL=Makhzoon Staging <staging-notifications@makhzoon.me>

# --- Cron ---
# Generate with: openssl rand -hex 32  (different value from dev and prod)
CRON_SECRET=

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
