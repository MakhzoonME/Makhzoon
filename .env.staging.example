# --- Supabase (public, safe to expose) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase Admin (server-side only, NEVER expose to client) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://stg.makhzoon.me
NODE_ENV=production
# Explicit environment identifier. Values: development | staging | production
# Do NOT rely on NODE_ENV — Vercel sets NODE_ENV=production for Preview and Production.
NEXT_PUBLIC_APP_ENV=staging

# --- Email (Resend) ---
# Use a separate Resend API key (or sandbox domain) so QA doesn't email real users
RESEND_API_KEY=
RESEND_FROM_EMAIL=Makhzoon Staging <staging-notifications@makhzoon.me>

# --- Cron ---
# Generate with: openssl rand -hex 32  (different value from dev and prod)
CRON_SECRET=

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Cloudflare Turnstile ---
