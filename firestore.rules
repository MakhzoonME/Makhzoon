rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null && request.auth.token.role == 'super_admin';
    }
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }
    function isOrgOwner() {
      return request.auth != null && request.auth.token.role == 'org_owner';
    }
    function isStaff() {
      return request.auth != null && request.auth.token.role == 'staff';
    }
    function belongsToOrg(orgId) {
      return request.auth.token.organizationId == orgId;
    }
    // Admin-or-stronger: anyone with manage rights inside an org.
    function isOrgManager(orgId) {
      return (isAdmin() || isOrgOwner()) && belongsToOrg(orgId);
    }

    match /organizations/{orgId} {
      allow read, write: if isSuperAdmin();
    }

    match /subscriptions/{subId} {
      allow read, write: if isSuperAdmin();
      allow read: if isOrgManager(resource.data.organizationId);
    }

    match /users/{userId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(resource.data.organizationId);
      allow read: if isStaff() && belongsToOrg(resource.data.organizationId);
    }

    match /assets/{assetId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(resource.data.organizationId);
      allow read: if isStaff() && belongsToOrg(resource.data.organizationId);
    }

    match /warranties/{warrantyId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(resource.data.organizationId);
      allow read: if isStaff() && belongsToOrg(resource.data.organizationId);
    }

    match /requests/{requestId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(resource.data.organizationId);
      allow read, create: if isStaff() && belongsToOrg(resource.data.organizationId);
    }

    match /auditLogs/{logId} {
      // Org Owner is intentionally excluded from audit logs per role spec.
      allow read: if isSuperAdmin();
      allow read: if isAdmin() && belongsToOrg(resource.data.organizationId);
      allow write: if false;
    }

    match /assetNotes/{noteId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(resource.data.organizationId);
      allow read, create: if isStaff() && belongsToOrg(resource.data.organizationId);
      allow delete: if isStaff() && belongsToOrg(resource.data.organizationId) && resource.data.createdBy == request.auth.uid;
    }

    match /maintenanceRecords/{recordId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(resource.data.organizationId);
      allow read: if isStaff() && belongsToOrg(resource.data.organizationId);
    }

    match /assetCheckouts/{checkoutId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(resource.data.organizationId);
      allow read, create, update: if isStaff() && belongsToOrg(resource.data.organizationId);
    }

    match /invites/{inviteId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(resource.data.organizationId);
    }

    // Per-org dropdown configuration (statuses, locations, categories).
    // Doc id is the organization id, so guard on the path id rather than data.
    match /organizationConfigs/{orgId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(orgId);
      allow read: if isStaff() && belongsToOrg(orgId);
    }

    // Tax rates — read-only for staff (used by Raseed, Purchases, Haraka).
    match /taxRates/{taxRateId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(resource.data.organizationId);
      allow create: if isOrgManager(request.resource.data.organizationId);
      allow read: if isStaff() && belongsToOrg(resource.data.organizationId);
    }

    // Purchases — stock-in records under Raseed.
    match /purchases/{purchaseId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(resource.data.organizationId);
      allow create: if isOrgManager(request.resource.data.organizationId);
      allow read: if isStaff() && belongsToOrg(resource.data.organizationId);
    }

    // POS sessions — cashier opens/closes their own; managers see all in org.
    match /posSessions/{sessionId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(resource.data.organizationId);
      allow create: if belongsToOrg(request.resource.data.organizationId);
      allow read, update: if isStaff() && belongsToOrg(resource.data.organizationId);
    }

    // POS transactions — append-only by cashier, read by managers + the cashier.
    match /posTransactions/{txId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(resource.data.organizationId);
      allow create: if belongsToOrg(request.resource.data.organizationId);
      allow read: if isStaff() && belongsToOrg(resource.data.organizationId);
    }

    // POS customers — shared per-org address book.
    match /posCustomers/{customerId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isOrgManager(resource.data.organizationId);
      allow create: if belongsToOrg(request.resource.data.organizationId);
      allow read, update: if isStaff() && belongsToOrg(resource.data.organizationId);
    }

    // Fawtara counters — per-org sequential invoice numbering. Admin SDK only in v1.
    match /fawtaraCounters/{orgId} {
      allow read: if isSuperAdmin();
      allow read: if isOrgManager(orgId);
      allow write: if false;
    }
  }
}
